{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sglang-risk/risk_profile.schema.json",
  "title": "Risk Profile",
  "type": "object",
  "required": ["feature", "probability", "impact", "composite_score", "level", "test_depth"],
  "properties": {
    "feature": {"type": "string"},
    "probability": {
      "type": "object",
      "properties": {
        "total": {"type": "integer", "minimum": 0, "maximum": 25},
        "max": {"type": "integer", "const": 25},
        "factors": {
          "type": "object",
          "properties": {
            "code_complexity": {"$ref": "#/$defs/factor"},
            "change_frequency": {"$ref": "#/$defs/factor"},
            "historical_defects": {"$ref": "#/$defs/factor"},
            "platform_divergence": {"$ref": "#/$defs/factor"},
            "dependency_depth": {"$ref": "#/$defs/factor"},
            "test_effectiveness": {"$ref": "#/$defs/factor"}
          }
        }
      }
    },
    "impact": {
      "type": "object",
      "properties": {
        "total": {"type": "integer", "minimum": 0, "maximum": 20},
        "max": {"type": "integer", "const": 20},
        "factors": {
          "type": "object",
          "properties": {
            "user_exposure": {"$ref": "#/$defs/factor"},
            "failure_mode": {"$ref": "#/$defs/factor"},
            "detectability": {"$ref": "#/$defs/factor"},
            "recovery_cost": {"$ref": "#/$defs/factor"}
          }
        }
      }
    },
    "composite_score": {"type": "integer", "minimum": 0, "maximum": 45},
    "level": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
    "test_depth": {"type": "string", "enum": ["L0", "L1", "L2", "L3"]},
    "fingerprint": {"type": "string"},
    "last_updated": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "factor": {
      "type": "object",
      "required": ["score"],
      "properties": {
        "score": {"type": "integer", "minimum": 1, "maximum": 5},
        "rationale": {"type": "string"},
        "source": {"type": "string", "enum": ["AST", "git", "defect_db", "manual", "dependency_map", "test_evaluator"]},
        "details": {"type": "object"}
      }
    }
  }
}
